### New Provider Template
```dart
import 'package:flutter_riverpod/flutter_riverpod.dart';

class ExampleState {
  final bool isLoading;
  final String? error;
  // ... fields

  const ExampleState({
    this.isLoading = false,
    this.error,
  });

  ExampleState copyWith({bool? isLoading, String? error}) {
    return ExampleState(
      isLoading: isLoading ?? this.isLoading,
      error: error ?? this.error,
    );
  }
}

class ExampleNotifier extends StateNotifier<ExampleState> {
  ExampleNotifier() : super(const ExampleState());

  Future<void> doSomething() async {
    state = state.copyWith(isLoading: true);
    try {
      // logic
    } catch (e) {
      state = state.copyWith(error: e.toString());
    } finally {
      state = state.copyWith(isLoading: false);
    }
  }
}

final exampleProvider =
    StateNotifierProvider<ExampleNotifier, ExampleState>((ref) {
  return ExampleNotifier();
});
```

### Gemini Call Template
```dart
Future<String> callGemini(String userMessage) async {
  final profile = ref.read(profileProvider);
  final habits = ref.read(habitProvider).habits;
  final recentMeals = await _foodLogRepo.getThisWeek();
  final recentChats = await _conversationRepo.getLast(3);

  final systemPrompt = _contextService.buildSystemPrompt(
    profile, habits, recentMeals, recentChats
  );

  final messages = [
    ...state.messages.map((m) => {'role': m.role, 'content': m.content}),
    {'role': 'user', 'content': userMessage},
  ];

  return _geminiService.sendMessage(
    messages: messages,
    systemPrompt: systemPrompt,
  );
}
```

